# --- DATABASE ---
DB_HOST=my_postgres 
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_user_password
DB_NAME=your_db

# --- KAFKA ---
KAFKA_BROKER=redpanda-clone:9092
KAFKA_BROKERS=redpanda-clone:9092 

# --- PROTOCOL FIX ---
# ✅ FIX: Changed 'password' to 'password123' to match DB_PASSWORD above
DATABASE_URL=postgres://postgres:password123@my_postgres:5432/security_db?sslmode=disable